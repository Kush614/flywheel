# Flywheel — sponsor credentials. Copy to .env and fill in as you wire each
# milestone. M0/M1/M4 need NONE of these (the fallback demo is zero-dependency).
# The whole point of Zero + Pomerium is that there are FEWER keys, not more.
#
# ALL credentials are CLI-minted — no hand-pasted keys needed. Run:
#   py -m integrations.status        # shows what's authed + the CLI to auth the rest
# CLIs (already installed): ant (Anthropic), nexla-cli (Nexla), zero (Zero.xyz).

# --- Dashboard -------------------------------------------------------------
PORT=8000
FLYWHEEL_PERIOD_DELAY=1.6      # seconds between loop periods (lower = faster demo)
FLYWHEEL_MAX_PERIODS=40

# --- M2: Anthropic (Claude as corrector) — auth via the `ant` CLI ----------
# Preferred:  ant auth login        (browser OAuth; the client fetches a token
#             with `ant auth print-credentials --access-token` automatically).
# Nothing to put here for the CLI path. ANTHROPIC_API_KEY only if you'd rather
# use a raw key instead of the CLI profile.
ANTHROPIC_API_KEY=
# Loop calls Claude once per period — for a snappy live demo prefer a fast model:
ANTHROPIC_MODEL=claude-opus-4-8   # or claude-sonnet-5, or claude-haiku-4-5 (fastest)

# --- M3: Nexla (governed Nexset) — auth via the `nexla-cli` ----------------
# Preferred:  nexla-cli login --service-key <key-from-express.dev>
# OR set NEXLA_SERVICE_KEY below and the client auto-runs that login to mint
# NEXLA_TOKEN on startup.
NEXLA_API_URL=https://dev-api-express-code.nexla.com/
NEXLA_SERVICE_KEY=            # from express.dev — auto-mints NEXLA_TOKEN via the CLI
NEXLA_TOKEN=                  # or paste a token from `nexla-cli login` directly
NEXLA_MONITORING_URL=https://veda-ai.nexla.io/monitoring/
NEXSET_ID=                    # the campaign-performance Nexset id, once provisioned

# --- M4: Pomerium (policy gate in front of the bid.actions MCP) ------------
# The local PolicyGate needs no env; these are for a real Pomerium deployment.
POMERIUM_GATEWAY_URL=
POMERIUM_AGENT_IDENTITY=agent:flywheel-loopA
POMERIUM_SESSION_BUDGET_CAP=200   # max total $ authorizable per loop session
POMERIUM_APPROVAL_THRESHOLD=4     # single bid changes above this need human approval

# --- M5: Zero.xyz (keyless API discovery + x402 wallet) --------------------
# Already live via `zero auth agent register` (managed wallet). Nothing required
# for free discovery. Set this ONLY to sign paid calls from your own wallet:
ZERO_PRIVATE_KEY=
# ZERO_RUNNER=                 # override the zero binary path if not auto-resolved

# --- M6: Fillmore by Metaview (Loop B outbound recruiting) -----------------
# No public API (waitlist only) -> Loop B runs on a stub. Fill if you get access.
FILLMORE_API_URL=
FILLMORE_API_KEY=
